{
  "name": "license-verification-system",
  "version": "2.0.0",
  "description": "Modern license verification system with Node.js API and React UI",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && cd client && npm install",
    "start": "node server.js",
    "dev": "node server.js",
