    "build-ui": "cd client && npm run build",
    "build": "npm run build-ui"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pdf-parse": "^1.1.1",
    "dotenv": "^16.0.3"
  }
}
